# shadownet configuration
# Copy to .env and fill in your values, or run ./setup.sh to generate it.

# ── Instance identity ─────────────────────────────────────────────────
# Public URL where this instance is reachable (include scheme)
SHADOWNET_EXTERNAL_URL=http://localhost:8340

# Display name for this agent
SHADOWNET_AGENT_NAME=shadownet

# Owner name shown in the agent card
SHADOWNET_OWNER_NAME=Your Name

# ── Auth ──────────────────────────────────────────────────────────────
# JWT secret — generate with: openssl rand -hex 32
SHADOWNET_JWT_SECRET=replace-with-a-long-random-string

# JWT token expiry in minutes (default: 10080 = 1 week)
# SHADOWNET_JWT_EXPIRE_MINUTES=10080

# ── Ports ─────────────────────────────────────────────────────────────
# Host ports for the UI/API and MCP server (defaults in docker-compose.yml)
# SHADOWNET_PORT=8340
# SHADOWNET_MCP_PORT=8341

# ── Docker networking ─────────────────────────────────────────────────
# Docker network your agent runs on.
# shadownet joins this network so the agent can reach MCP on port 8341
# and shadownet can reach the agent's webhook on port 8644.
#
# Find it with: docker network ls
AGENT_NETWORK=agent-network

# ── Notifications ────────────────────────────────────────────────────
# Webhook URL for user-facing notifications.
# When an A2A message arrives, shadownet POSTs to this URL.
#
# For Hermes Agent: http://<agent-container>:8644/webhooks/a2a-inbox
# See agent-config.example.yaml for the agent-side webhook routes.
#
# Leave empty to disable.
# SHADOWNET_NOTIFICATION_WEBHOOK_URL=http://hermes-agent:8644/webhooks/a2a-inbox

# Separate URL for autonomous agent negotiation (coordination_request).
# Falls back to NOTIFICATION_WEBHOOK_URL if empty.
# SHADOWNET_NOTIFICATION_NEGOTIATE_URL=http://hermes-agent:8644/webhooks/a2a-negotiate

# HMAC-SHA256 secret for webhook signature validation.
# Must match the secret in the agent's webhook route config.
# Generate with: openssl rand -hex 32
# SHADOWNET_NOTIFICATION_WEBHOOK_SECRET=replace-with-shared-secret

# ── Traefik (optional) ───────────────────────────────────────────────
# Only needed with docker-compose.traefik.yml overlay.
# TRAEFIK_HOST=your-host.example.com
