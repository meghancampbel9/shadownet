# shadownet-local (v0.2) configuration
# Copy to .env and fill in values, or run ./setup.sh to generate it.

# Public URL of this instance. The self-signed AgentCard and this Shadow's
# shadow://key:...@host:port connection URI derive from it (https:// in prod).
SHADOWNET_EXTERNAL_URL=https://your-instance.example.com

# Addressing (RFC 0001 §3):
#   direct     — identity is the Ed25519 key; self-signed AgentCard, no DNS (default)
#   shadowname — run as your own provider for a domain (needs DNS _shadownet.<domain>)
SHADOWNET_ADDRESSING_MODE=direct
# Only for shadowname mode:
# SHADOWNET_SHADOWNAME=you@your-domain.example
# SHADOWNET_PROVIDER_DOMAIN=your-domain.example

# Identity shown in the AgentCard
SHADOWNET_AGENT_NAME=shadownet
SHADOWNET_OWNER_NAME=Your Name

# Trust (RFC 0001 §7). Empty trust store = no issuer trusted yet (populate as you
# join Hubs/orgs). Stranger policy defaults to requiring org_affiliation.
SHADOWNET_TRUST_STORE=[]
# SHADOWNET_ACCEPTANCE_POLICY={"fromContact":[],"fromStranger":["org_affiliation"]}
# SHADOWNET_SAME_PROVIDER_ORG=false
# Path to a file/dir of org_affiliation credential JWTs this Subject presents:
# SHADOWNET_CREDENTIALS_PATH=./data/credentials

# Portal / access-token signing secret — generate with: openssl rand -hex 32
SHADOWNET_JWT_SECRET=replace-with-a-long-random-string
# SHADOWNET_JWT_EXPIRE_MINUTES=10080  # 1 week

# Host port for the UI/API
# SHADOWNET_PORT=8340

# Docker network your host agent runs on (container-to-container access)
AGENT_NETWORK=agent-network

# Traefik overlay (optional): TRAEFIK_HOST=your-host.example.com
