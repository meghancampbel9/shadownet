# hermes-social configuration
# Copy to .env and fill in your values, or run ./setup.sh to generate it.

# ── Instance identity ─────────────────────────────────────────────────
# Public URL where this instance is reachable (include scheme)
HERMES_SOCIAL_EXTERNAL_URL=http://localhost:8340

# Display name for this agent
HERMES_SOCIAL_AGENT_NAME=hermes-social

# Owner name shown in the agent card
HERMES_SOCIAL_OWNER_NAME=Your Name

# ── Auth ──────────────────────────────────────────────────────────────
# JWT secret — generate with: openssl rand -hex 32
HERMES_SOCIAL_JWT_SECRET=replace-with-a-long-random-string

# JWT token expiry in minutes (default: 10080 = 1 week)
# HERMES_SOCIAL_JWT_EXPIRE_MINUTES=10080

# ── Ports ─────────────────────────────────────────────────────────────
# Host ports for the UI/API and MCP server (defaults in docker-compose.yml)
# HERMES_SOCIAL_PORT=8340
# HERMES_SOCIAL_MCP_PORT=8341

# ── Docker networking ─────────────────────────────────────────────────
# Docker network your Hermes agent runs on.
# hermes-social joins this network so the agent can reach MCP on port 8341
# and hermes-social can reach the agent's webhook on port 8644.
#
# Find it with: docker network ls | grep hermes
HERMES_NETWORK=hermes-network

# ── Notifications ────────────────────────────────────────────────────
# Webhook URL for agent wake-up notifications.
# When an A2A message arrives, hermes-social POSTs to this URL.
#
# For Hermes Agent: http://<agent-container>:8644/webhooks/a2a-inbox
# See agent-config.example.yaml for the agent-side webhook routes.
#
# Leave empty to disable.
# HERMES_SOCIAL_NOTIFICATION_WEBHOOK_URL=http://hermes-agent:8644/webhooks/a2a-inbox

# HMAC-SHA256 secret for webhook signature validation.
# Must match the secret in the agent's webhook route config.
# Generate with: openssl rand -hex 32
# HERMES_SOCIAL_NOTIFICATION_WEBHOOK_SECRET=replace-with-shared-secret

# ── Traefik (optional) ───────────────────────────────────────────────
# Only needed with docker-compose.traefik.yml overlay.
# TRAEFIK_HOST=srv1234567.hstgr.cloud
