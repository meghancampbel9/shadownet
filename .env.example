# shadownet-local configuration
# Copy to .env and fill in your values, or run ./setup.sh to generate it.

# ── Instance identity ─────────────────────────────────────────────────
# Public URL where this instance is reachable (must be https:// for plugin).
SHADOWNET_EXTERNAL_URL=https://your-instance.example.com

# Shadowname in local@provider format (required for plugin integration).
# Example: meghan@shadownet.example.com
SHADOWNET_SHADOWNAME=

# Display name for this agent
SHADOWNET_AGENT_NAME=shadownet

# Owner name shown in the agent card
SHADOWNET_OWNER_NAME=Your Name

# ── Auth ──────────────────────────────────────────────────────────────
# JWT secret — generate with: openssl rand -hex 32
# This is also the token agents use as SHADOWNET_TOKEN for plugin auth.
SHADOWNET_JWT_SECRET=replace-with-a-long-random-string

# JWT token expiry in minutes (default: 10080 = 1 week)
# SHADOWNET_JWT_EXPIRE_MINUTES=10080

# ── Ports ─────────────────────────────────────────────────────────────
# Host ports for the UI/API and MCP server
# SHADOWNET_PORT=8340
# SHADOWNET_MCP_PORT=8341

# ── Docker networking ─────────────────────────────────────────────────
# Docker network your agent runs on (for container-to-container access).
# Find it with: docker network ls
AGENT_NETWORK=agent-network

# ── Traefik (optional) ───────────────────────────────────────────────
# Only needed with docker-compose.traefik.yml overlay.
# TRAEFIK_HOST=your-host.example.com
