# shadownet-local — copy to .env and fill in values

# Public URL of this instance (used in agent card and A2A routing)
SHADOWNET_EXTERNAL_URL=http://localhost:8340

# Identity shown in the agent card
SHADOWNET_AGENT_NAME=shadownet
SHADOWNET_OWNER_NAME=User

# Secret for signing web auth JWTs — change this in production
SHADOWNET_JWT_SECRET=CHANGE-ME-IN-PRODUCTION
SHADOWNET_JWT_ALGORITHM=HS256
SHADOWNET_JWT_EXPIRE_MINUTES=10080  # 1 week

# Database (SQLite path or connection string)
SHADOWNET_DATABASE_URL=sqlite:///./data/shadownet.db
SHADOWNET_DATA_DIR=./data

# Outbound A2A request tuning
SHADOWNET_AGENT_REQUEST_TIMEOUT=30
SHADOWNET_AGENT_RETRY_ATTEMPTS=3
SHADOWNET_AGENT_RETRY_BASE_DELAY=2.0

# Webhook: user-facing notifications (inbound messages, plan responses, etc.)
SHADOWNET_NOTIFICATION_WEBHOOK_URL=
SHADOWNET_NOTIFICATION_WEBHOOK_SECRET=

# Webhook: autonomous agent negotiations (coordination_request).
# Falls back to NOTIFICATION_WEBHOOK_URL if empty.
SHADOWNET_NOTIFICATION_NEGOTIATE_URL=
