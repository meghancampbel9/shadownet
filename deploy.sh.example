#!/usr/bin/env bash
set -euo pipefail

# ── Configuration ─────────────────────────────────────────────────────
# Customize these for your deployment.

VPS_HOST="${VPS_HOST:-root@your-server.example.com}"
REMOTE_DIR="${REMOTE_DIR:-/docker/shadownet}"
LOCAL_DIR="$(cd "$(dirname "$0")" && pwd)"

# Agent skills directories on the remote host (space-separated).
AGENT_SKILLS_DIRS="${AGENT_SKILLS_DIRS:-/path/to/agent-a/data/skills /path/to/agent-b/data/skills}"

# Agent containers to restart gateways in (space-separated).
AGENT_CONTAINERS="${AGENT_CONTAINERS:-agent-a agent-b}"

# Docker compose files to use.
COMPOSE_FILES="${COMPOSE_FILES:--f docker-compose.yml -f docker-compose.traefik.yml}"

# ── Helpers ───────────────────────────────────────────────────────────
info()  { printf '\033[1;34m▸ %s\033[0m\n' "$*"; }
ok()    { printf '\033[1;32m✓ %s\033[0m\n' "$*"; }
warn()  { printf '\033[1;33m⚠ %s\033[0m\n' "$*"; }

# ── Sync source to VPS ───────────────────────────────────────────────
info "Syncing $LOCAL_DIR → $VPS_HOST:$REMOTE_DIR"

rsync -avz --delete \
  --exclude '.git/' \
  --exclude 'node_modules/' \
  --exclude '__pycache__/' \
  --exclude '.venv/' \
  --exclude 'frontend/dist/' \
  --exclude 'data/' \
  --exclude 'data-test/' \
  --exclude '.env' \
  --exclude '.env.test' \
  --exclude '.env.local' \
  --exclude '.env.production' \
  --exclude '*.db' \
  --exclude '*.pyc' \
  "$LOCAL_DIR/" "$VPS_HOST:$REMOTE_DIR/"

ok "Source synced"

# ── Sync skills to agent(s) ──────────────────────────────────────────
if [ -d "$LOCAL_DIR/skills" ]; then
  for skills_dir in $AGENT_SKILLS_DIRS; do
    info "Syncing skills → $VPS_HOST:$skills_dir"
    rsync -avz "$LOCAL_DIR/skills/" "$VPS_HOST:$skills_dir/"
  done
  ok "Skills synced"
fi

# ── Build & restart on VPS ────────────────────────────────────────────
info "Building and restarting containers on VPS"
ssh "$VPS_HOST" "cd $REMOTE_DIR && docker compose $COMPOSE_FILES build --no-cache && docker compose $COMPOSE_FILES up -d"
ok "Deploy complete"

# ── Wipe agent memory + sessions (prevents stale beliefs) ────────────
for container in $AGENT_CONTAINERS; do
  info "Wiping memory and sessions in $container"
  ssh "$VPS_HOST" "
    docker exec $container sh -c 'echo \"\" > /opt/data/memories/MEMORY.md 2>/dev/null; rm -f /opt/data/sessions/session_*.json; echo \"{}\" > /opt/data/sessions/sessions.json 2>/dev/null' || true
  " 2>/dev/null && ok "Wiped: $container" || warn "Could not wipe: $container"
done

# ── Clear sidecar interaction history ─────────────────────────────────
info "Clearing sidecar interaction history"
ssh "$VPS_HOST" "
  docker exec shadownet python3 -c \"import sqlite3; c=sqlite3.connect('/app/data/shadownet.db'); c.execute('DELETE FROM interaction_contexts'); c.commit(); c.close()\" 2>/dev/null
" && ok "Interaction history cleared" || warn "Could not clear interaction history"

# ── Restart agent gateways ────────────────────────────────────────────
for container in $AGENT_CONTAINERS; do
  info "Restarting gateway in $container"
  ssh "$VPS_HOST" "
    docker exec $container sh -c 'hermes gateway stop 2>/dev/null' || true
    sleep 1
    docker exec -d $container sh -c 'hermes gateway run --replace > /tmp/gateway.log 2>&1'
  " 2>/dev/null && ok "Gateway restarted: $container" || warn "Could not restart gateway: $container"
done

# ── Verify ────────────────────────────────────────────────────────────
info "Checking container status"
ssh "$VPS_HOST" "cd $REMOTE_DIR && docker compose ps"
